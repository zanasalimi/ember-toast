{
  "name": "@embertoast/react",
  "version": "0.0.0",
  "description": "Headless-first toast primitive for React: toast() + <Toaster/>. Accessible, promise-aware, zero runtime deps.",
  "author": "Zana Salimi",
  "license": "MIT",
  "keywords": ["react", "toast", "notification", "headless", "a11y", "sonner"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanasalimi/embertoast.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/zanasalimi/embertoast#readme",
  "bugs": "https://github.com/zanasalimi/embertoast/issues",
  "sideEffects": ["*.css"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@embertoast/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "size-limit": [
    {
      "name": "react binding (ESM, incl. core, tree-shaken)",
      "path": "dist/index.js",
      "gzip": true,
      "limit": "3.5 kB"
    }
  ]
}
