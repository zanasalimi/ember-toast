{
  "name": "@embertoast/core",
  "version": "0.0.0",
  "description": "Framework-agnostic toast store and imperative facade. Zero runtime dependencies.",
  "author": "Zana Salimi",
  "license": "MIT",
  "keywords": ["toast", "notification", "headless", "store", "pubsub"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanasalimi/embertoast.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/zanasalimi/embertoast#readme",
  "bugs": "https://github.com/zanasalimi/embertoast/issues",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "size-limit": [
    {
      "name": "core (ESM, tree-shaken)",
      "path": "dist/index.js",
      "gzip": true,
      "limit": "1.2 kB"
    }
  ]
}
