{
  "name": "embertoast-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Headless-first toast primitive for React — monorepo root.",
  "author": "Zana Salimi",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "size": "turbo run size --filter=./packages/*",
    "clean": "turbo run clean && rimraf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "rimraf": "^6.0.1",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "human-id@>=4.2.0": "4.1.3"
    }
  }
}
